{
  "name": "gh-admin.com",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && tsc --noEmit",
    "husky": "husky",
    "preview": "pnpm run build && vite preview",
    "predeploy:dev": "pnpm run wrangler types && pnpm run build && wrangler secret bulk .dev.vars.dev --env dev",
    "deploy:dev": "wrangler deploy --no-bundle --env dev",
    "postdeploy:dev": "pnpm run lint:fix",
    "predeploy:prod": "pnpm run wrangler types && pnpm run build && wrangler secret bulk .dev.vars.prod --env prod",
    "deploy:prod": "wrangler deploy --no-bundle --env prod",
    "postdeploy:prod": "pnpm run lint:fix",
    "cf:typegen": "wrangler types",
    "tanstack:generate-routes": "tsr generate",
    "typecheck": "tsc --noEmit",
    "check": "tsc && vite build && wrangler deploy --no-bundle --dry-run",
    "biome": "biome",
    "components:add": "shadcn add",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "auth:generate": "npx @better-auth/cli@latest generate --config server/auth/index.ts --output server/db/schemas/auth.ts --yes",
    "db:generate": "drizzle-kit generate --schema=./server/db/schemas --out=./server/db/migrations --dialect=sqlite",
    "db:migrate:local": "wrangler d1 migrations apply GH_ADMIN_D1_PRIMARY --local",
    "db:migrate:dev": "wrangler d1 migrations apply GH_ADMIN_D1_PRIMARY --env dev --remote",
    "db:migrate:prod": "wrangler d1 migrations apply GH_ADMIN_D1_PRIMARY --remote --env prod",
    "db:studio:dev": "drizzle-kit studio --config=./drizzle.config.ts",
    "db:studio:prod": "NODE_ENV=production drizzle-kit studio  --config=./drizzle.config.ts",
    "wrangler": "wrangler",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "browser": "agent-browser",
    "test:e2e": "playwright test"
  },
  "cloudflare": {
    "label": "gh-admin.com",
    "products": [
      "Workers",
      "Durable Objects"
    ],
    "categories": [
      "storage"
    ]
  },
  "dependencies": {
    "zod": "^4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@cloudflare/vite-plugin": "^1.26.1",
    "@cloudflare/workers-types": "^4.20260307.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24",
    "agent-browser": "^0.17.1",
    "globals": "^17.4.0",
    "nock": "^14.0.11",
    "otpauth": "^9.5.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.71.0"
  },
  "pnpm": {
    "patchedDependencies": {
      "@cloudflare/ai-chat@0.1.8": "patches/@cloudflare__ai-chat@0.1.8.patch"
    }
  }
}
